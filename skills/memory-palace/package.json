    "@types/uuid": "^10.0.0",
    "canvas": "^3.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "@types/uuid": "^9.0.0"
  }
