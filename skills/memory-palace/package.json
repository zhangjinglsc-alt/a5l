{
  "name": "memory-palace",
  "version": "1.8.5",
  "description": "Memory Palace - Cognitive enhancement layer for OpenClaw agents with semantic search, time reasoning, knowledge graphs, and experience accumulation",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "memory-palace": "./bin/memory-palace.js"
  },
  "scripts": {
    "build": "tsc",
