{
  "tier1": {
    "name": "范式级",
    "description": "TAM上修≥50% / 技术主流化 / 供需结构变化",
    "position_limit": "20-25%",
    "holding_period": "季度→年度",
    "patterns": [
      "TAM.*(上调|翻倍|增长|扩大).*?(\\d+)%",
      "市场规模.*(翻倍|扩大|上调)",
      "(成为|确立).*主流",
      "(行业|产业).*格局.*改变",
      "供需.*(不可逆|永久)",
      "(技术|路线).*主流化",
      "(范式|革命性).*变化",
      "TAM从.*亿.*上调至.*亿"
    ],
    "keywords": [
      "TAM上调",
      "市场规模翻倍",
      "成为主流",
      "格局改变",
      "不可逆",
      "范式转移",
      "革命性",
      "确立标准",
      "行业采用"
    ]
  },
  "tier2": {
    "name": "周期确认级",
    "description": "供需缺口确认 / 龙头订单指引上修",
    "position_limit": "15-20%",
    "holding_period": "月度→季度",
    "patterns": [
      "LTA",
      "长协",
      "锁定.*产能",
      "订单.*排至.*20\\d{2}",
      "订单.*超预期",
      "指引.*上调",
      "产能.*(满载|饱和)",
      "(涨价|价格).*持续.*(至|到).*20\\d{2}"
    ],
    "keywords": [
      "长协",
      "锁定产能",
      "订单超预期",
      "指引上调",
      "产能满载",
      "LTA",
      "涨价周期"
    ]
  },
  "tier3": {
    "name": "资金驱动级",
    "description": "大额订单>100亿 / 重大政策 / 龙头战略合作",
    "position_limit": "10-15%",
    "holding_period": "周度→月度",
    "patterns": [
      "(\\d+)亿.*(订单|合同)",
      "战略.*(合作|签约)",
      "(收购|合并|重组)",
      "政策.*(出台|发布)",
      "补贴",
      "规划.*发布",
      "(大单|巨额).*订单"
    ],
    "keywords": [
      "亿订单",
      "战略合作",
      "收购",
      "政策出台",
      "补贴",
      "大单",
      "巨额合同"
    ]
  },
  "tier4": {
    "name": "补涨扩散级",
    "description": "与主线关联间接 / 纯粹涨价叙事",
    "position_limit": "5-10%",
    "holding_period": "日度→周度",
    "patterns": [
      "涨价",
      "价格.*上调",
      "供不应求",
      "补涨",
      "扩散",
      "关联.*(板块|概念)",
      "跟风"
    ],
    "keywords": [
      "涨价",
      "价格上调",
      "补涨",
      "扩散",
      "跟风",
      "替代",
      "关联"
    ]
  },
  "consensus_signals": {
    "description": "一致性高潮信号",
    "patterns": [
      "(\\d+)只涨停",
      "板块.*涨停",
      "板块涨幅.*(\\d+)%",
      "一字板",
      "连板",
      "高潮",
      "集体涨停"
    ],
    "keywords": [
      "涨停潮",
      "集体涨停",
      "板块高潮",
      "一字板",
      "连板"
    ]
  }
}