# A5L - ARCHITECT-5L Super Skill
# Git Ignore Configuration

# System files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Data & Logs (保留结构，忽略内容)
/data/**/*.json
/data/**/*.csv
/data/**/*.xlsx
/logs/*.log
/logs/*.json

# Sensitive files
config/secrets.json
config/*_token*
config/*_key*
*.pem
*.key

# Temporary files
/tmp/
/temp/
*.tmp

# Large binary files
*.zip
*.tar.gz
*.rar

# Node modules (if any)
node_modules/

# Archive (keep structure, ignore large files)
/archive/**/*.zip
/archive/**/*.tar.gz

# Feishu export (can be regenerated)
/feishu_export/*.md

# Keep directory structure
!.gitkeep

# Session备份文件 (由系统自动生成，不需要版本控制)
.backup/sessions/active/*
.backup/sessions/daily/*
!.backup/sessions/milestones/*/

# 运行时日志 (不需要版本控制)
.evolution/*.log
feishu_sync_log.json
skills/auto-briefing/data/*.log

# 第三方工具/依赖目录 (不加入版本控制)
m_flow/
skills/agent-memory-system-guide/agent-memory-system-guide/
