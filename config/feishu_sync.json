    "memory": {
      "folder": "03-MOUL（记忆层）/每日情景记忆",
      "filename_pattern": "MEMORY-{date}.md",
      "format": "doc"
    },
    "goal": {
      "folder": "04-GOAL（目标层）",
      "filename_pattern": "GOAL-进展-{date}.md",
      "format": "doc"
    },
    "data": {
      "folder": "05-DATA（数据层）",
      "filename_pattern": "DATA-持仓-{date}",
      "format": "bitable"
    }
