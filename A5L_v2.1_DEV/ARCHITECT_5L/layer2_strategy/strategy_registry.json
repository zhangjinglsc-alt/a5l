          "percent": 20
        }
      },
      {
        "indicator": "volume",
        "condition": "above_avg",
        "params": {
          "multiplier": 1.5
        }
      }
    ],
    "exit_rules": [
      {
        "indicator": "stop_loss",
        "condition": "trailing",
        "params": {
          "percent": 5
        }
      },
      {
        "indicator": "rs_rank",
        "condition": "drop_below",
        "params": {
          "percent": 30
        }
      }
    ],
    "risk_params": {
      "max_position_pct": 8,
      "stop_loss_pct": 5
    },
    "active": true
  },
