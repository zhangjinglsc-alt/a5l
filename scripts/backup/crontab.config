# A5L Smart Backup System - Cron配置
# 添加到crontab: crontab -e

# Tier 1: SSMG核心数据备份 (每日23:30)
30 23 * * * /workspace/projects/workspace/scripts/backup/tier1_core_backup.sh

# Tier 2: 知识图谱备份 (每日23:45)
45 23 * * * /workspace/projects/workspace/scripts/backup/tier2_kg_backup.sh

# 健康检查 (每日23:55)
55 23 * * * /workspace/projects/workspace/scripts/backup/health_check.sh

# 月度归档 (每月1日00:00)
0 0 1 * * /workspace/projects/workspace/scripts/backup/monthly_archive.sh
